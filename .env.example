# .env.example

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# GitHub App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=./keys/github-app.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Jira
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_CLIENT_ID=...
JIRA_CLIENT_SECRET=...

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_NOTIFICATION_CHANNEL=#engineering-decisions

# Postgres connection string
DATABASE_URL=postgresql://lore:lorepass@postgres:5432/lore

# Cognee Deployment Mode: 'local' (open-source package) or 'cloud' (API)
COGNEE_MODE=local
REDIS_URL=redis://redis:6379

# Cognee (Dual-Deployment Strategy)
# Mode determines which backend to use. Must be either 'local' or 'cloud'.
COGNEE_MODE=local

# Cloud Config (Used when COGNEE_MODE=cloud)
COGNEE_API_KEY=...

# Local Config (Used when COGNEE_MODE=local)
COGNEE_GRAPH_DB=neo4j
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j-password

# App
APP_URL=https://lore.yourdomain.com
SECRET_KEY=your-jwt-secret
