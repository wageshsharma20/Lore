# Database configuration (Postgres managed locally or externally in prod)
DATABASE_URL=postgresql://lore:YOUR_SECURE_PASSWORD@postgres:5432/lore
DB_PASSWORD=YOUR_SECURE_PASSWORD

# Redis (For Celery tasks and Caching)
CELERY_BROKER_URL=redis://redis:6379/0

# Claude API Key for the Historian Extractor & Decision Memory features
ANTHROPIC_API_KEY=sk-ant-YOUR_PROD_API_KEY

# GitHub Configuration for Webhooks & PR blocking
GITHUB_TOKEN=ghp_YOUR_PROD_GITHUB_PAT
GITHUB_WEBHOOK_SECRET=YOUR_SECURE_WEBHOOK_SECRET

# Cognee Cloud / Graph DB Settings
COGNEE_MODE=cloud
COGNEE_API_KEY=YOUR_COGNEE_CLOUD_API_KEY
COGNEE_CLOUD_URL=https://api.cognee.ai

# If you choose to host Neo4j yourself (e.g., Neo4j AuraDB)
NEO4J_URI=neo4j+s://YOUR_AURADB_ID.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=YOUR_AURADB_PASSWORD

# API Settings
ENV=production
CORS_ORIGINS=https://lore.yourcompany.com
